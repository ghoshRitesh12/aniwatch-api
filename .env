ANIWATCH_API_CORS_ALLOWED_ORIGINS=https://just-anime.flexyy.xyz,https://flexyy.hostmafia.us.cc,https://zoro.anipirate.site

ANIWATCH_API_DEPLOYMENT_ENV=vercel
ANIWATCH_API_HOSTNAME=https://api-zoro.flexyy.xyz

# 🔥 Rate Limit (Almost Unlimited)
ANIWATCH_API_WINDOW_MS=60000
ANIWATCH_API_MAX_REQS=999999

# 🔥 Disable IP Based Limiting (agar middleware support karta ho)
ANIWATCH_API_RATE_LIMIT_BY_IP=false
ANIWATCH_API_TRUST_PROXY=true

# Cache
ANIWATCH_API_S_MAXAGE=1
ANIWATCH_API_STALE_WHILE_REVALIDATE=10
